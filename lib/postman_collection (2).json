						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": "{{baseUrl}}/api/v1/groups/{{groupId}}/start",
						"description": "Only the group creator can start the group. This generates the payout turns and sets the startDate."
					}
				}
			]
		},
		{
			"name": "04. Payments & Transactions",
			"item": [
