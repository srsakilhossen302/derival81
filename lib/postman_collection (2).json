						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Savings Group Alpha\",\n    \"description\": \"(optional) saving for dream car\",\n    \"contributionAmount\": 1000,\n    \"contributionFrequency\": \"monthly\",\n    \"totalMembers\": 5,\n    \"totalCycles\": 2,\n    \"startDate\": \"2024-12-01\"\n}",
							"options": { "raw": { "language": "json" } }
