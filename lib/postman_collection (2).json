				{
					"name": "Get Group Members",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
						"url": "{{baseUrl}}/api/v1/group-members/{{groupId}}"
					}
